{
  "name": "weekly-commit-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "bdd": "bddgen && playwright test --project=bdd",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "contracts:capture": "node ../tests/contracts/run.mjs --mode=capture",
    "contracts:verify": "node ../tests/contracts/run.mjs --mode=verify"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-oauth/google": "^0.13.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.60.0",
    "flowbite-react": "^0.12.17",
    "framer-motion": "^12.35.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@eslint/js": "^9.39.4",
    "@originjs/vite-plugin-federation": "^1.3.6",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "playwright-bdd": "^8.5.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^5.4.11",
    "vitest": "^4.0.18"
  }
}

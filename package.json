{
  "name": "st6-weekly-commit-module",
  "version": "0.1.0",
  "private": true,
  "description": "ST6 Weekly Commit Module — micro-frontend weekly-commit tracker (Spring Boot + React)",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "test": "npm --prefix frontend run test:run",
    "e2e": "npm --prefix frontend run e2e",
    "bdd": "npm --prefix frontend run bdd",
    "lint": "npm --prefix frontend run lint",
    "format": "npm --prefix frontend run format",
    "format:check": "npm --prefix frontend run format:check",
    "contracts:capture": "node tests/contracts/run.mjs --mode=capture",
    "contracts:verify": "node tests/contracts/run.mjs --mode=verify",
    "backend:build": "docker build -t weekly-commit-backend:local backend",
    "backend:up": "docker compose up -d --build",
    "backend:down": "docker compose down"
  },
  "devDependencies": {
    "nx": "^20.2.0"
  }
}

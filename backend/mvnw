#!/bin/sh
# Maven Wrapper script — downloads Maven if not present
# Licensed under the Apache License 2.0

set -e

if [ -z "$MAVEN_WRAPPER_JAR" ]; then
    MAVEN_WRAPPER_JAR="$(dirname "$0")/.mvn/wrapper/maven-wrapper.jar"
fi

if [ -z "$MAVEN_HOME" ]; then
    MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.9"
fi

MVN_CMD="$MAVEN_HOME/bin/mvn"

if [ ! -f "$MVN_CMD" ]; then
    echo "Downloading Maven 3.9.9..."
    DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"
    mkdir -p "$MAVEN_HOME"
    TMPFILE=$(mktemp /tmp/maven-XXXXXX.zip)
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL -o "$TMPFILE" "$DIST_URL"
    elif command -v wget > /dev/null 2>&1; then
        wget -q -O "$TMPFILE" "$DIST_URL"
    else
        echo "Error: curl or wget required to download Maven" >&2
        exit 1
    fi
    unzip -q -o "$TMPFILE" -d "$(dirname "$MAVEN_HOME")"
    rm -f "$TMPFILE"
fi

exec "$MVN_CMD" "$@"
